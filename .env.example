# LX_MUSIC_SOURCE_SCRIPT
# https://lxmusic.toside.cn/desktop/custom-source
LX_MUSIC_SOURCE_SCRIPT=https://c.wwwweb.top/script/lxmusic?key=<your-real-key>

# Local SQLite database and shared music data root.
DATABASE_URL=file:./data/app.sqlite
MUSIC_DATA_DIR=./data

# Optional QQ Music login fallback.
# Prefer importing Cookie in the UI or using QR login. If set here, use the
# full Cookie request header from an authenticated y.qq.com request.
# Some private account APIs need uin plus qm_keyst/qqmusic_key; favorites read
# may also need euin/encryptUin or enc_host_uin captured from QQ Music requests.
# QQ_MUSIC_COOKIE=uin=o123456789; qm_keyst=...; qqmusic_key=...; euin=...

# Required upstream Emby server for the miXmusic Emby-compatible gateway.
# Emby clients can point at miXmusic; implemented routes are handled locally and
# unimplemented routes are forwarded to this upstream.
EMBY_UPSTREAM_URL=http://127.0.0.1:8096
EMBY_API_KEY=<emby-api-key>
EMBY_PROXY_TIMEOUT_MS=30000

# Built-in tagging and file organization.
# When online metadata is enabled, miXmusic fetches QQ Music detail, lyrics, and
# cover art, writes supported MP3/FLAC tags, and stores Emby-friendly sidecars
# beside the organized track in MUSIC_DATA_DIR/music.
TAGGING_WRITE_TAGS=true
TAGGING_FETCH_ONLINE_METADATA=true
TAGGING_ORGANIZE_FILES=true
TAGGING_FETCH_TIMEOUT_MS=5000

# Background worker polling and retry settings.
WORKER_POLL_INTERVAL_MS=5000
WORKER_MAX_ATTEMPTS=3

# Public UI label.
NEXT_PUBLIC_APP_NAME=miXmusic
