# Production/server port. Local `npm run dev` uses 3004.
PORT=8098

# Optional host port for the ampcast container started by Docker Compose.
AMPCAST_PORT=8000

# Local SQLite database and shared music data root.
MUSIC_DATA_DIR=./data
DATABASE_URL=file:./data/app.sqlite

# LX_MUSIC_SOURCE_SCRIPT
# Use a private LX Music custom source URL with its key/apiKey query value.
LX_MUSIC_SOURCE_SCRIPT=https://example.com/lxmusic/source?key=<your-real-key>

# Optional QQ Music login fallback.
# Prefer importing Cookie in the UI or using QR login. If set here, use the
# full Cookie request header from an authenticated y.qq.com request.
# Some private account APIs need uin plus qm_keyst/qqmusic_key; favorites read
# may also need euin/encryptUin or enc_host_uin captured from QQ Music requests.
# QQ_MUSIC_COOKIE=uin=o123456789; qm_keyst=...; qqmusic_key=...; euin=...

# QQ UINs allowed to access admin-only pages such as user management and jobs.
# Accepts comma, semicolon, or whitespace separated values.
ADMIN_QQ_UINS=<your-qq-uin>

# Required upstream Emby server for the XMusic Emby-compatible gateway.
# Emby clients can point at XMusic; implemented routes are handled locally and
# unimplemented routes are forwarded to this upstream.
EMBY_UPSTREAM_URL=http://127.0.0.1:8096
EMBY_API_KEY=<emby-api-key>
EMBY_PROXY_TIMEOUT_MS=30000

# Request logging to stdout for Docker/Dokploy logs. "auto" enables logs in
# production and keeps local `next dev` on Next's built-in request output.
# Use true to force-enable locally, false to reduce production log volume.
X_MUSIC_REQUEST_LOGS=auto

# Optional: upload finalized music files, covers, and lyrics to the upstream
# Emby server's music library over WebDAV before requesting an Emby scan.
# The URL path should point at the same directory that Emby sees as its music
# library root, for example /volume1/music.
# EMBY_SOURCE_WEBDAV_DSN=https://user:password@example.com/dav/music

# Built-in tagging and file organization.
# When online metadata is enabled, XMusic fetches QQ Music detail, lyrics, and
# cover art, writes supported MP3/FLAC tags, and stores Emby-friendly sidecars
# beside the organized track in MUSIC_DATA_DIR/music.
TAGGING_WRITE_TAGS=true
TAGGING_FETCH_ONLINE_METADATA=true
TAGGING_ORGANIZE_FILES=true
TAGGING_FETCH_TIMEOUT_MS=5000

# Background worker polling and retry settings.
WORKER_POLL_INTERVAL_MS=5000
WORKER_MAX_ATTEMPTS=3

# Public UI label.
NEXT_PUBLIC_APP_NAME=XMusic

# Optional production-only analytics script tag.
# Use the complete script tag code provided by your analytics service.
# ANALYTICS_SCRIPT_CODE='<script src="https://example.com/analytics.js?id=<site-id>"></script>'
